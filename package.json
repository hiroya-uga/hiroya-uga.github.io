{
  "name": "hiroya-uga.github.io",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "git -C notes lfs install --local && git -C notes lfs pull && node scripts/copy-blog-images.mjs && node scripts/copy-notes-media.mjs && next build && next-sitemap",
    "build:analyze": "ANALYZE=true next build",
    "dev": "git -C notes lfs install --local && git -C notes lfs pull && node scripts/copy-blog-images.mjs && node scripts/copy-notes-media.mjs && next dev -p 3001",
    "dev:md": "node scripts/watch-media.mjs",
    "fix": "yarn lint:fix && yarn format:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "generate-ogp-alt": "node scripts/create-opengraph-image-alt-txt.mjs",
    "postinstall": "node scripts/rebuild-canvas.mjs",
    "lint": "yarn lint:oxlint && yarn lint:stylelint && yarn lint:textlint",
    "lint:fix": "oxlint --fix . --ignore-path .oxlintignore && stylelint --fix 'src/**/*.css' && yarn lint:textlint:fix",
    "lint:oxlint": "oxlint . --ignore-path .oxlintignore",
    "lint:stylelint": "stylelint 'src/**/*.css'",
    "lint:textlint": "textlint 'notes/**/*.md'",
    "lint:textlint:fix": "textlint --fix 'notes/**/*.md'",
    "next-lint": "next lint",
    "prepare": "husky",
    "start": "next start",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "oxlint --fix --ignore-path .oxlintignore --no-error-on-unmatched-pattern",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "resolutions": {
    "brace-expansion@^1.1.7": "1.1.14",
    "lodash": "4.18.1",
    "minimatch@9.0.3": "9.0.9",
    "minimatch@^3.0.5": "3.1.5",
    "minimatch@^3.1.1": "3.1.5",
    "minimatch@^3.1.2": "3.1.5",
    "minimatch@^9.0.4": "9.0.9",
    "picomatch@^4.0.3": "4.0.4",
    "postcss@8.4.31": "8.5.10",
    "postcss@^8.4.41": "^8.5.10",
    "postcss@^8.5.6": "^8.5.10",
    "postcss@^8.5.8": "^8.5.10"
  },
  "dependencies": {
    "@shikijs/rehype": "^4.1.0",
    "@types/node": "24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "color-convert": "^3.1.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "jquery": "^3.7.1",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "marked": "^15.0.12",
    "next": "^16.2.6",
    "next-mdx-remote": "6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-ga4": "^2.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "schema-dts": "^1.1.2",
    "shiki": "^4.1.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@next/mdx": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/gtag.js": "^0.0.20",
    "@types/jquery": "^3.5.19",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/mdx": "^2.0.13",
    "@types/youtube": "^0.1.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.5.0",
    "canvas": "^3.2.3",
    "clsx": "^2.1.1",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "next-sitemap": "^4.2.3",
    "oxlint": "^1.66.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-eslint-cli": "^8.0.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "sort-package-json": "^3.6.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.0",
    "textlint": "^15.7.1",
    "textlint-rule-prh": "^6.1.0",
    "vitest": "^4.1.7"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24.14.1"
  }
}
