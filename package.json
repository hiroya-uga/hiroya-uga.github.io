{
  "name": "hiroya-uga.github.io",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/copy-blog-images.mjs && next build && next-sitemap",
    "build:analyze": "ANALYZE=true next build",
    "dev": "node scripts/copy-blog-images.mjs && next dev -p 3001",
    "dev:articles": "node scripts/watch-blog-images.mjs",
    "fix": "yarn lint:fix && yarn format:fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "generate-ogp-alt": "node scripts/create-opengraph-image-alt-txt.mjs",
    "postinstall": "node scripts/rebuild-canvas.mjs",
    "lint": "yarn lint:oxlint && yarn lint:stylelint",
    "lint:fix": "oxlint --fix . --ignore-path .oxlintignore && stylelint --fix 'src/**/*.css'",
    "lint:oxlint": "oxlint . --ignore-path .oxlintignore",
    "lint:stylelint": "stylelint 'src/**/*.css'",
    "next-lint": "next lint",
    "prepare": "husky",
    "start": "next start",
    "test": "vitest --run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "oxlint --fix --ignore-path .oxlintignore",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,mdx}": [
      "prettier --write"
    ],
    "package.json": [
      "sort-package-json"
    ]
  },
  "dependencies": {
    "@shikijs/rehype": "^4.0.2",
    "@types/node": "24",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "color-convert": "^3.1.3",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.8.0",
    "jquery": "^3.7.1",
    "lodash": "^4.18.1",
    "markdown-it": "^14.1.1",
    "marked": "^15.0.12",
    "next": "^16.2.3",
    "next-mdx-remote": "6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-ga4": "^2.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-html": "^16.0.1",
    "schema-dts": "^1.1.2",
    "shiki": "^4.0.2",
    "typescript": "^6.0.2"
  },
  "devDependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/bundle-analyzer": "^16.1.3",
    "@next/mdx": "^16.1.3",
    "@tailwindcss/postcss": "^4.1.10",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/gtag.js": "^0.0.20",
    "@types/jquery": "^3.5.19",
    "@types/lodash": "^4.17.18",
    "@types/markdown-it": "^14.1.2",
    "@types/mdx": "^2.0.5",
    "@types/youtube": "^0.1.2",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.16",
    "canvas": "^3.1.2",
    "clsx": "^2.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "next-sitemap": "^4.2.3",
    "oxlint": "^0.8.0",
    "postcss": "^8.5.10",
    "prettier": "^3.3.3",
    "prettier-eslint-cli": "^8.0.1",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "sort-package-json": "^3.6.1",
    "stylelint": "^17.6.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.1.10",
    "vitest": "^4.0.18"
  },
  "packageManager": "yarn@4.13.0",
  "engines": {
    "node": ">=24.14.1"
  }
}
